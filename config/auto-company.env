GITHUB_USER=  # auto-detected from 'gh auth login' if left empty
ACTIVE_PROJECT=undefined

# GITHUB_REPO: optional override for the GitHub repository used by the active project.
# If unset, the framework derives it automatically as "${GITHUB_USER}/${ACTIVE_PROJECT}".
# Uncomment and set this only when the repo name differs from ACTIVE_PROJECT, or when
# the repo lives under a different owner (e.g. an org account).
#GITHUB_REPO=<github-user>/<repo-name>
